{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"$ORCA_PANE_KEY\" ] && [ -z \"$ORCA_AGENT_HOOK_PORT\" ]; then terminal-notifier -title 'Codex' -message 'Awaiting your input'; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"$ORCA_PANE_KEY\" ] && [ -z \"$ORCA_AGENT_HOOK_PORT\" ]; then terminal-notifier -title 'Codex' -message 'Task completed'; fi"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -r '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -x '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ]; then /bin/sh '/Users/mukit/.orca/agent-hooks/codex-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -r '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -x '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ]; then /bin/sh '/Users/mukit/.orca/agent-hooks/codex-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -r '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -x '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ]; then /bin/sh '/Users/mukit/.orca/agent-hooks/codex-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "S=\"$HOME/.local/bin/rm-guard\"; if [ -r \"$S\" ]; then exec bash \"$S\"; fi; CMD=$(cat); if printf '%s' \"$CMD\" | grep -Eq '(^|[^[:alnum:]_])rm([^[:alnum:]_]|$)'; then echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"rm-guard script missing; blocking rm for safety\"}}'; fi; exit 0",
            "timeout": 10,
            "statusMessage": "Checking rm target safety"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -r '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -x '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ]; then /bin/sh '/Users/mukit/.orca/agent-hooks/codex-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -r '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -x '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ]; then /bin/sh '/Users/mukit/.orca/agent-hooks/codex-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -r '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -x '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ]; then /bin/sh '/Users/mukit/.orca/agent-hooks/codex-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -r '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -x '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ]; then /bin/sh '/Users/mukit/.orca/agent-hooks/codex-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -f '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -r '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -x '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ]; then /bin/sh '/Users/mukit/.orca/agent-hooks/codex-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
