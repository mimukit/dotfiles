{
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"$ORCA_PANE_KEY\" ] && [ -z \"$ORCA_AGENT_HOOK_PORT\" ]; then terminal-notifier -title 'Codex' -message 'Awaiting your input'; fi"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$ORCA_PANE_KEY\" ] && [ -n \"$ORCA_AGENT_HOOK_PORT\" ] && [ -f '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -r '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -x '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ]; then /bin/sh '/Users/mukit/.orca/agent-hooks/codex-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$ORCA_PANE_KEY\" ] && [ -n \"$ORCA_AGENT_HOOK_PORT\" ] && [ -f '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -r '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -x '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ]; then /bin/sh '/Users/mukit/.orca/agent-hooks/codex-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -z \"$ORCA_PANE_KEY\" ] && [ -z \"$ORCA_AGENT_HOOK_PORT\" ]; then terminal-notifier -title 'Codex' -message 'Task completed'; fi"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$ORCA_PANE_KEY\" ] && [ -n \"$ORCA_AGENT_HOOK_PORT\" ] && [ -f '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -r '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ] && [ -x '/Users/mukit/.orca/agent-hooks/codex-hook.sh' ]; then /bin/sh '/Users/mukit/.orca/agent-hooks/codex-hook.sh'; else cat >/dev/null 2>&1 || :; fi",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
