{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "effortLevel": "medium",
  "env": {
    "DISABLE_TELEMETRY": "1",
    "IS_DEMO": "1"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "terminal-notifier -title 'Claude Code' -message 'Awaiting your input'",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/mukit/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "terminal-notifier -title 'Claude Code' -message 'Task completed'",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Read(~/.zshrc)",
      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(xargs:*)",
      "Bash(npm:*)",
      "Bash(pnpm:*)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Bash(rm:*)"
    ]
  },
  "statusLine": {
    "command": "bash ~/.claude/statusline-command.sh",
    "type": "command"
  },
  "theme": "dark"
}
